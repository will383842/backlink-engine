// ─────────────────────────────────────────────────────────────
// Backlink Engine – Prisma Schema (Enhanced with Enums & Cascades)
// ─────────────────────────────────────────────────────────────

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────
// ENUMS (Type Safety)
// ─────────────────────────────────────────────────────────────

enum ProspectStatus {
  NEW
  ENRICHING
  READY_TO_CONTACT
  CONTACTED_EMAIL
  CONTACTED_MANUAL
  FOLLOWUP_DUE
  REPLIED
  NEGOTIATING
  WON
  LINK_PENDING
  LINK_VERIFIED
  LINK_LOST
  RE_CONTACTED
  LOST
  DO_NOT_CONTACT
}

enum ProspectSource {
  manual
  csv_import
  scraper
}

enum EmailStatus {
  unverified
  verified
  invalid
  risky // Suspicious but not confirmed invalid (e.g., catch-all domain)
  disposable // Temporary email service (10minutemail.com, etc.)
  role // Role-based email (info@, contact@, support@)
}

enum EnrollmentStatus {
  active
  stopped
  completed
}

enum LinkType {
  dofollow
  nofollow
  sponsored
  ugc
  mixed
}

// Language is now a free String field (ISO 639-1 codes: "fr", "en", "nl", "ja", etc.)
// to support ALL languages worldwide. The old enum was too restrictive.
// Fallback: "en" (English) when language is unknown or unsupported.

enum UserRole {
  ops
  admin
}

enum ProspectCategory {
  blogger
  association
  partner
  influencer
  media
  agency
  corporate
  ecommerce
  other
}

enum TagCategory {
  type // Type de site (blogueur, presse, influenceur)
  sector // Secteur (assurance, finance, voyage, tech, santé)
  quality // Qualité (premium, verified, partner)
  geography // Géographie (france, europe, international)
  source // Source (scraper, manual, import)
  other
}

// ─────────────────────────────────────────────────────────────
// NEW ENUMS (v2)
// ─────────────────────────────────────────────────────────────

enum OpportunityType {
  guest_post
  resource_link
  mention
  partnership
  affiliate
  interview
  guest_content
  broken_link
  skyscraper
  infographic
}

enum PageType {
  homepage
  country
  emergency
  stats
  service
  blog
}

enum AssetCategory {
  article
  guide
  stats_page
  infographic
  widget
  logo
  banner
  affiliate_link
}

enum NegotiationStatus {
  pending_response
  article_requested
  link_exchange_proposed
  payment_discussed
  agreed
  rejected
}

enum NegotiationType {
  guest_post
  link_exchange
  paid
  partnership
  widget
}

enum CrawlSourceType {
  blog_directory
  search_engine
  competitor_backlinks
  write_for_us
}

enum CrawlResultStatus {
  new_result
  processed
  rejected
}

enum TaskStatus {
  pending
  in_progress
  completed
}

enum PartnerApplicationStatus {
  pending
  approved
  rejected
}

enum PartnerConversionType {
  click
  signup
  call
}

enum CampaignType {
  outreach
  broadcast
}

enum VerificationTier {
  T1 // daily
  T2 // weekly
  T3 // bi-weekly
  T4 // monthly
}

// ─────────────────────────────────────────────────────────────
// 1. Prospect
// ─────────────────────────────────────────────────────────────

model Prospect {
  id                    Int              @id @default(autoincrement())
  domain                String           @unique
  source                ProspectSource   @default(manual)
  category              ProspectCategory @default(blogger)
  sourceContactType     String?          @db.VarChar(30) // Original type from Mission Control (presse, blog, influenceur, youtubeur, instagrammeur...)
  language              String?          @db.VarChar(10) // ISO 639-1 (fr, en, nl, ja...)
  country               String?          @db.VarChar(2) // ISO 3166-1 alpha-2
  timezone              String?          @db.VarChar(50) // IANA timezone (e.g., "Europe/Paris")
  tier                  Int              @default(1)
  score                 Int              @default(0)
  mozDa                 Int?
  openPagerank          Decimal?
  spamScore             Int              @default(0)
  hasRealTraffic        Boolean          @default(false)
  isPbn                 Boolean          @default(false)
  linkNeighborhoodScore Int?
  outboundCategories    Json?
  contactFormUrl        String?
  contactFormFields     Json? // Detected form fields: {name, email, message, subject, etc.}
  hasCaptcha            Boolean? // Whether form has CAPTCHA
  phone                 String?
  phoneCountryCode      String?          @db.VarChar(5) // +33, +49, etc.
  status                ProspectStatus   @default(NEW)
  firstContactedAt      DateTime?
  lastContactedAt       DateTime?
  nextFollowupAt        DateTime?
  // v2 fields
  opportunityType       OpportunityType?
  opportunityNotes      String?
  thematicRelevance     Int? // 0-10 relevance to expat niche
  thematicCategories    Json? // array of detected themes
  assignedToId          Int?
  verificationTier      VerificationTier @default(T3)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  sourceUrls         SourceUrl[]
  contacts           Contact[]
  enrollments        Enrollment[]
  events             Event[]
  backlinks          Backlink[]
  tags               ProspectTag[]
  negotiations       Negotiation[]
  taskAssignments    TaskAssignment[]
  sentEmails         SentEmail[]
  partnerApplication PartnerApplication?
  assignedTo         User?              @relation("ProspectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Simple indexes
  @@index([status])
  @@index([tier])
  @@index([country])
  @@index([language])
  @@index([timezone])
  @@index([category])
  @@index([nextFollowupAt])
  @@index([score])
  @@index([assignedToId])
  // Composite indexes for common queries
  @@index([status, score])
  @@index([status, tier])
  @@index([category, language])
  @@index([category, country])
  @@map("prospects")
}

// ─────────────────────────────────────────────────────────────
// 2. SourceUrl
// ─────────────────────────────────────────────────────────────

model SourceUrl {
  id              Int      @id @default(autoincrement())
  prospectId      Int
  url             String
  urlNormalized   String   @unique
  canonicalUrl    String?
  title           String?
  metaDescription String?
  discoveredVia   String   @default("manual")
  notes           String?
  createdAt       DateTime @default(now())

  prospect  Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  backlinks Backlink[]

  @@index([prospectId])
  @@map("source_urls")
}

// ─────────────────────────────────────────────────────────────
// 3. Contact
// ─────────────────────────────────────────────────────────────

model Contact {
  id              Int         @id @default(autoincrement())
  prospectId      Int
  email           String
  emailNormalized String      @unique
  firstName       String?
  lastName        String?
  name            String? // DEPRECATED: Use firstName + lastName instead (kept for backward compatibility)
  role            String      @default("unknown")
  sourceContactType String?   @db.VarChar(30) // Original type from Mission Control (presse, youtubeur, instagrammeur...)
  emailStatus     EmailStatus @default(unverified)
  discoveredVia   String      @default("manual")
  softBounceCount Int         @default(0)
  optedOut        Boolean     @default(false)
  optedOutAt      DateTime?
  createdAt       DateTime    @default(now())

  prospect    Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  events      Event[]
  sentEmails  SentEmail[]
  exclusions  BroadcastExclusion[]

  @@index([prospectId])
  @@index([emailStatus])
  @@index([optedOut])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// 4. Campaign
// ─────────────────────────────────────────────────────────────

model Campaign {
  id              Int               @id @default(autoincrement())
  name            String
  campaignType    CampaignType      @default(outreach)
  language        String            @db.VarChar(10)
  targetTier      Int?
  targetCountry   String?
  targetCategory  ProspectCategory?
  mailwizzListUid String?
  sequenceConfig  Json?
  stopOnReply     Boolean           @default(true)
  stopOnUnsub     Boolean           @default(true)
  stopOnBounce    Boolean           @default(true)
  abTestEnabled   Boolean           @default(false)
  // ── Broadcast-specific fields ──
  brief                    String?  @db.Text
  sourceEmail              Json?
  targetSourceContactTypes Json?
  warmupSchedule           Json?
  currentWarmupDay         Int      @default(0)
  // ── Counters (used by both modes, essential for broadcast stats) ──
  totalEnrolled   Int               @default(0)
  totalReplied    Int               @default(0)
  totalWon        Int               @default(0)
  totalSent       Int               @default(0)
  totalDelivered  Int               @default(0)
  totalOpened     Int               @default(0)
  totalClicked    Int               @default(0)
  totalBounced    Int               @default(0)
  totalComplained Int               @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())

  enrollments       Enrollment[]
  sentEmails        SentEmail[]
  tags              CampaignTag[]
  exclusions        BroadcastExclusion[]
  manualRecipients  BroadcastManualRecipient[]

  @@index([isActive])
  @@index([language])
  @@index([isActive, language])
  @@index([campaignType, isActive])
  @@map("campaigns")
}

// ─────────────────────────────────────────────────────────────
// 5. Enrollment
// ─────────────────────────────────────────────────────────────

model Enrollment {
  id                    Int              @id @default(autoincrement())
  contactId             Int
  campaignId            Int
  prospectId            Int
  mailwizzSubscriberUid String?
  mailwizzListUid       String?
  campaignRef           String?
  currentStep           Int              @default(0)
  status                EnrollmentStatus @default(active)
  stoppedReason         String?
  enrolledAt            DateTime         @default(now())
  lastSentAt            DateTime?
  nextSendAt            DateTime?
  completedAt           DateTime?

  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  prospect     Prospect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  events       Event[]
  sentEmails   SentEmail[]
  negotiations Negotiation[]

  @@unique([contactId, campaignId])
  @@index([status])
  @@index([nextSendAt])
  @@index([prospectId])
  @@index([campaignId])
  @@index([status, nextSendAt])
  @@index([campaignId, status])
  @@map("enrollments")
}

// ─────────────────────────────────────────────────────────────
// 5b. SentEmail - Full audit trail of every email sent
// ─────────────────────────────────────────────────────────────

model SentEmail {
  id              Int      @id @default(autoincrement())
  enrollmentId    Int
  prospectId      Int
  contactId       Int
  campaignId      Int
  stepNumber      Int      // 0 = initial, 1+ = follow-ups
  // Sending inbox (for per-inbox deliverability analytics)
  fromEmail       String?  @db.VarChar(255)
  // Full email content (as actually sent)
  subject         String
  body            String   @db.Text
  language        String   @db.VarChar(5)
  // Generation metadata
  generatedBy     String   @default("ai") // "ai" | "template" | "manual"
  promptContext   Json?    // Input data used to generate the email
  // MailWizz tracking
  mailwizzCampaignUid String?
  mailwizzMessageId   String?
  // Delivery status (updated by webhooks)
  // Statuses: draft (pending review), approved (ready to send), rejected (will not send),
  //           sent, delivered, opened, clicked, bounced, complained, failed
  status          String   @default("sent")
  sentAt          DateTime?
  deliveredAt     DateTime?
  firstOpenedAt   DateTime?
  openCount       Int      @default(0)
  firstClickedAt  DateTime?
  clickCount      Int      @default(0)
  bouncedAt       DateTime?
  bounceType      String?  // hard, soft
  complainedAt    DateTime?
  abVariant       String?  @db.VarChar(1) // "A" or "B" or null (no A/B test)

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  prospect   Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  contact    Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([prospectId])
  @@index([contactId])
  @@index([status])
  @@index([sentAt])
  @@index([campaignId, stepNumber])
  @@index([campaignId, abVariant])
  @@index([fromEmail])
  @@index([fromEmail, sentAt])
  @@map("sent_emails")
}

// ─────────────────────────────────────────────────────────────
// 6. Event (append-only)
// ─────────────────────────────────────────────────────────────

model Event {
  id           Int      @id @default(autoincrement())
  prospectId   Int
  contactId    Int?
  enrollmentId Int?
  eventType    String
  eventSource  String
  userId       Int?
  data         Json?
  createdAt    DateTime @default(now())

  prospect   Prospect    @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  contact    Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([prospectId])
  @@index([contactId])
  @@index([enrollmentId])
  @@index([eventType])
  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([eventType, prospectId, createdAt])
  @@index([userId, createdAt])
  @@map("events")
}

// ─────────────────────────────────────────────────────────────
// 7. Backlink
// ─────────────────────────────────────────────────────────────

model Backlink {
  id               Int              @id @default(autoincrement())
  prospectId       Int
  sourceUrlId      Int?
  targetPageId     Int? // FK to TargetPage (v2)
  pageUrl          String
  targetUrl        String
  anchorText       String?
  linkType         LinkType         @default(dofollow)
  isVerified       Boolean          @default(false)
  lastVerifiedAt   DateTime?
  isLive           Boolean          @default(true)
  lostAt           DateTime?
  hasWidget        Boolean          @default(false)
  hasBadge         Boolean          @default(false)
  firstDetectedAt  DateTime?
  verificationTier VerificationTier @default(T3)
  lastIndexCheckAt DateTime?
  isIndexed        Boolean?
  createdAt        DateTime         @default(now())

  prospect   Prospect    @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  sourceUrl  SourceUrl?  @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  targetPage TargetPage? @relation(fields: [targetPageId], references: [id], onDelete: SetNull)

  @@index([prospectId])
  @@index([sourceUrlId])
  @@index([targetPageId])
  @@index([isLive])
  @@index([targetUrl])
  @@index([prospectId, isLive])
  @@index([verificationTier, lastVerifiedAt])
  @@index([createdAt, isLive])
  @@index([linkType, isLive])
  @@map("backlinks")
}

// ─────────────────────────────────────────────────────────────
// 8. LinkableAsset
// ─────────────────────────────────────────────────────────────

model LinkableAsset {
  id                 Int            @id @default(autoincrement())
  title              String
  slug               String         @unique
  assetType          String
  url                String
  description        String?
  content            String?        @db.Text
  fileUrl            String?
  thumbnailUrl       String?
  category           AssetCategory?
  availableLanguages Json           @default("[\"fr\",\"en\"]")
  targetCountries    Json? // array of ISO country codes
  targetLanguages    Json? // array of language codes
  totalBacklinks     Int            @default(0)
  totalMentions      Int            @default(0)
  isPublished        Boolean        @default(false)
  publishedAt        DateTime?
  createdAt          DateTime       @default(now())

  negotiations Negotiation[]

  @@index([assetType])
  @@index([isPublished])
  @@index([category])
  @@map("linkable_assets")
}

// ─────────────────────────────────────────────────────────────
// 9. OutreachTemplate
// ─────────────────────────────────────────────────────────────

model OutreachTemplate {
  id             Int               @id @default(autoincrement())
  name           String
  language       String            @db.VarChar(10)
  category       ProspectCategory?
  purpose        String
  subject        String
  body           String
  formalityLevel String            @default("formal")
  culturalNotes  String?
  timesUsed      Int               @default(0)
  replyRate      Decimal?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  tags           TemplateTag[]

  @@index([language])
  @@index([category])
  @@index([purpose])
  @@index([isActive])
  @@index([language, category])
  @@map("outreach_templates")
}

// ─────────────────────────────────────────────────────────────
// 10. SuppressionEntry
// ─────────────────────────────────────────────────────────────

model SuppressionEntry {
  id              Int      @id @default(autoincrement())
  emailNormalized String   @unique
  reason          String
  source          String
  createdAt       DateTime @default(now())

  @@map("suppression_entries")
}

// ─────────────────────────────────────────────────────────────
// 11. AppSetting (key-value JSON store)
// ─────────────────────────────────────────────────────────────

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────────────────────────────────
// 12. User
// ─────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  role         UserRole @default(ops)
  passwordHash String
  createdAt    DateTime @default(now())

  events          Event[]
  taskAssignments TaskAssignment[]
  assignedProspects Prospect[]     @relation("ProspectAssignee")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// 13. MessageTemplate (Contact form templates by language)
// ─────────────────────────────────────────────────────────────

model MessageTemplate {
  id        Int               @id @default(autoincrement())
  language  String   @db.VarChar(10) // ISO 639-1 (fr, en, nl, ja...)
  category  ProspectCategory? // Optional category (blogger, media, etc.) - null = general template
  subject   String // Sujet du message
  body      String            @db.Text // Corps du message avec variables: {siteName}, {yourName}, {yourCompany}, {yourWebsite}
  isDefault Boolean           @default(false) // Is this the default template for this language?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([language, category]) // One template per language+category combination
  @@index([language])
  @@index([category])
  @@index([isDefault])
  @@map("message_templates")
}

// ─────────────────────────────────────────────────────────────
// 14. TargetPage (pages we want backlinks TO)
// ─────────────────────────────────────────────────────────────

model TargetPage {
  id             Int      @id @default(autoincrement())
  url            String   @unique
  slug           String   @unique
  title          String
  description    String?
  pageType       PageType
  country        String?  @db.VarChar(2)
  language       String?  @db.VarChar(10)
  priority       Int      @default(5) // 1-10
  totalBacklinks Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  anchorStrategies AnchorStrategy[]
  backlinks        Backlink[]

  @@index([pageType])
  @@index([isActive])
  @@index([country])
  @@map("target_pages")
}

// ─────────────────────────────────────────────────────────────
// 15. AnchorStrategy (anchor text distribution control)
// ─────────────────────────────────────────────────────────────

model AnchorStrategy {
  id                Int      @id @default(autoincrement())
  targetPageId      Int
  anchorType        String // brand, url, generic, long_tail, keyword, lsi
  targetPercentage  Decimal
  currentPercentage Decimal  @default(0)
  createdAt         DateTime @default(now())

  targetPage TargetPage @relation(fields: [targetPageId], references: [id], onDelete: Cascade)

  @@unique([targetPageId, anchorType])
  @@index([targetPageId])
  @@map("anchor_strategies")
}

// ─────────────────────────────────────────────────────────────
// 16. SendingQuota (daily email sending limits)
// ─────────────────────────────────────────────────────────────

model SendingQuota {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique @db.Date
  emailsSent Int      @default(0)
  maxAllowed Int      @default(100)
  createdAt  DateTime @default(now())

  @@map("sending_quotas")
}

// ─────────────────────────────────────────────────────────────
// 17. Competitor & CompetitorBacklink
// ─────────────────────────────────────────────────────────────

model Competitor {
  id             Int       @id @default(autoincrement())
  domain         String    @unique
  name           String
  lastAnalyzedAt DateTime?
  totalBacklinks Int       @default(0)
  createdAt      DateTime  @default(now())

  backlinks CompetitorBacklink[]

  @@map("competitors")
}

model CompetitorBacklink {
  id                Int       @id @default(autoincrement())
  competitorId      Int
  sourceUrl         String
  sourceDomain      String
  anchorText        String?
  linkType          LinkType?
  isAlsoLinkingToUs Boolean   @default(false)
  createdAt         DateTime  @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, sourceUrl])
  @@index([competitorId])
  @@index([sourceDomain])
  @@index([isAlsoLinkingToUs])
  @@map("competitor_backlinks")
}

// ─────────────────────────────────────────────────────────────
// 18. Negotiation (post-reply workflow)
// ─────────────────────────────────────────────────────────────

model Negotiation {
  id               Int               @id @default(autoincrement())
  prospectId       Int
  enrollmentId     Int?
  status           NegotiationStatus @default(pending_response)
  type             NegotiationType
  requestedAssetId Int?
  offeredPayment   Decimal?          @db.Decimal(10, 2)
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  prospect       Prospect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  enrollment     Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  requestedAsset LinkableAsset? @relation(fields: [requestedAssetId], references: [id], onDelete: SetNull)

  @@index([prospectId])
  @@index([enrollmentId])
  @@index([status])
  @@map("negotiations")
}

// ─────────────────────────────────────────────────────────────
// 19. CrawlSource & CrawlResult (autonomous source discovery)
// ─────────────────────────────────────────────────────────────

model CrawlSource {
  id            Int             @id @default(autoincrement())
  name          String
  type          CrawlSourceType
  baseUrl       String?
  config        Json            @default("{}")
  lastCrawledAt DateTime?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  results CrawlResult[]

  @@index([type])
  @@index([isActive])
  @@map("crawl_sources")
}

model CrawlResult {
  id              Int               @id @default(autoincrement())
  crawlSourceId   Int
  url             String
  domain          String
  title           String?
  metaDescription String?
  rawData         Json?
  status          CrawlResultStatus @default(new_result)
  prospectId      Int?
  createdAt       DateTime          @default(now())

  crawlSource CrawlSource @relation(fields: [crawlSourceId], references: [id], onDelete: Cascade)

  @@unique([crawlSourceId, domain])
  @@index([status])
  @@index([domain])
  @@index([crawlSourceId])
  @@map("crawl_results")
}

// ─────────────────────────────────────────────────────────────
// 20. TaskAssignment (team management)
// ─────────────────────────────────────────────────────────────

model TaskAssignment {
  id          Int        @id @default(autoincrement())
  userId      Int
  prospectId  Int?
  description String
  status      TaskStatus @default(pending)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([userId, status])
  @@index([status, dueDate])
  @@map("task_assignments")
}

// ─────────────────────────────────────────────────────────────
// 21. Partner Program (blogger partner system)
// ─────────────────────────────────────────────────────────────

model PartnerApplication {
  id         Int                      @id @default(autoincrement())
  prospectId Int?                     @unique
  domain     String
  email      String
  name       String
  language   String?  @db.VarChar(10)
  country    String?                  @db.VarChar(2)
  message    String?                  @db.Text
  status     PartnerApplicationStatus @default(pending)
  reviewedAt DateTime?
  createdAt  DateTime                 @default(now())

  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  partner  Partner?

  @@index([status])
  @@index([email])
  @@map("partner_applications")
}

model Partner {
  id               Int      @id @default(autoincrement())
  applicationId    Int      @unique
  affiliateCode    String   @unique
  dashboardToken   String   @unique
  totalClicks      Int      @default(0)
  totalConversions Int      @default(0)
  totalEarnings    Decimal  @default(0) @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  conversions PartnerConversion[]

  @@index([affiliateCode])
  @@index([dashboardToken])
  @@index([isActive])
  @@map("partners")
}

model PartnerConversion {
  id          Int                   @id @default(autoincrement())
  partnerId   Int
  type        PartnerConversionType
  referrerUrl String?
  createdAt   DateTime              @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([type])
  @@index([createdAt])
  @@map("partner_conversions")
}

// ─────────────────────────────────────────────────────────────
// Tag System (Multi-tagging for prospects)
// ─────────────────────────────────────────────────────────────

model Tag {
  id          Int         @id @default(autoincrement())
  name        String      @unique // "presse_ecrite", "assurance", "premium"
  label       String // "Presse Écrite", "Assurance", "Premium"
  description String? // Description du tag
  color       String      @default("#3B82F6") // Couleur hexa pour UI
  category    TagCategory @default(other)
  isAutoTag   Boolean     @default(false) // Auto-assigné par enrichissement
  createdAt   DateTime    @default(now())

  prospects ProspectTag[]
  campaigns CampaignTag[]
  templates TemplateTag[]

  @@index([category])
  @@index([isAutoTag])
  @@map("tags")
}

model ProspectTag {
  prospectId Int
  tagId      Int
  assignedBy String   @default("auto") // "auto" | "user:{userId}" | "enrichment" | "manual"
  createdAt  DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([prospectId, tagId])
  @@index([prospectId])
  @@index([tagId])
  @@map("prospect_tags")
}

model CampaignTag {
  campaignId Int
  tagId      Int
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([campaignId, tagId])
  @@index([campaignId])
  @@index([tagId])
  @@map("campaign_tags")
}

model TemplateTag {
  templateId Int
  tagId      Int
  createdAt  DateTime @default(now())

  template OutreachTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag      Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@index([templateId])
  @@index([tagId])
  @@map("template_tags")
}

// ─────────────────────────────────────────────────────────────
// Broadcast Management
// ─────────────────────────────────────────────────────────────

model BroadcastExclusion {
  id         Int      @id @default(autoincrement())
  campaignId Int
  contactId  Int
  reason     String?  @db.VarChar(255)
  excludedAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@map("broadcast_exclusions")
}

model BroadcastManualRecipient {
  id          Int       @id @default(autoincrement())
  campaignId  Int
  email       String    @db.VarChar(320)
  name        String?   @db.VarChar(255)
  contactType String?   @db.VarChar(30)
  language    String?   @db.VarChar(10)
  status      String    @default("pending")
  sentAt      DateTime?
  addedAt     DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, email])
  @@index([campaignId])
  @@index([status])
  @@map("broadcast_manual_recipients")
}
